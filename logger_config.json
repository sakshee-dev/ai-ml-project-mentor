{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "simple": {
      "format": "%(asctime)s - %(levelname)s - %(filename)s:%(lineno)s - %(message)s "
    },
    "raw": {
       "format": "%(message)s"
    }
  },

  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "simple",
      "stream": "ext://sys.stdout"
    },

    "file_handler": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "INFO",
      "formatter": "simple",
      "filename": "log/log.txt",
      "maxBytes": 10485760,
      "backupCount": 10,
      "encoding": "utf8"
    }
  },

  "loggers": {
    "clog": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    },
    "log_file": {
      "level": "INFO",
      "handlers": ["file_handler"],
      "propagate": false
    },
    "log_console_file": {
      "level": "INFO",
      "handlers": ["console","file_handler"],
      "propagate": false
    }
  },

  "root": {
    "level": "INFO",
    "handlers": ["console", "file_handler"]
  }
}
